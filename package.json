{
  "name": "formulia-cloud",
  "private": true,
  "version": "0.1.0",
  "description": "FormulIA Cloud monorepo",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "check": "npm run check:web-api-boundaries && npm run check --workspaces --if-present",
    "check:web-api-boundaries": "python scripts/check_frontend_api_boundaries.py",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "check:legacy": "python scripts/legacy_formula_parity.py --limit 20",
    "dev:web": "npm --workspace apps/web run dev -- -H 127.0.0.1 -p 3000",
    "build:web": "npm --workspace apps/web run build"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
